// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../server/generated"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                String    @id @default(uuid())
  name              String    @db.VarChar(255)
  cpf               String    @unique
  email             String?   @db.VarChar(255)
  dn                DateTime?
  phone             String?
  responsable_name  String?   @db.VarChar(255)
  responsable_phone String?
  active            Boolean   @default(true)

  enrollments Enrollment[]

  @@map("students")
}

model Course {
  id     String  @id @default(uuid())
  title  String  @db.VarChar(255)
  active Boolean @default(true)

  teams Team[]

  @@map("courses")
}

model Team {
  id             String    @id @default(uuid())
  course_id      String
  title          String    @db.VarChar(255)
  team_leader_id String?
  start_date     DateTime?
  end_date       DateTime?
  horary         String?
  days_of_week   String?
  active         Boolean   @default(true)
  payment_date   DateTime?
  price          Decimal   @db.Decimal(10, 2)

  course Course @relation(fields: [course_id], references: [id])

  enrollments Enrollment[]

  @@index([course_id])

  @@map("teams")
}

model Enrollment {
  id String @id @default(uuid())

  team_id    String
  student_id String

  student Student @relation(fields: [student_id], references: [id])
  team    Team    @relation(fields: [team_id], references: [id])

  charges Charge[]
  payments Payment[]

  @@unique([team_id, student_id])
  @@index([student_id])
  @@index([team_id])
  @@map("enrollments")
}

model Charge {
  id            String @id @default(uuid())
  enrollment_id String

  year  Int
  month Int

  amount   Decimal  @db.Decimal(10, 2)
  due_date DateTime
  paid     Boolean  @default(false)

  status ChargeStatus @default(PENDING)

  payments Payment[]

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id])

  @@unique([enrollment_id, year, month])
  @@map("charges")
}

model Payment {
  id String @id @default(uuid())

  enrollment_id String
  charge_id     String
  amount        Decimal       @db.Decimal(10, 2)
  payment_date  DateTime      @default(now())
  method        PaymentMethod

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id])
  charge     Charge     @relation(fields: [charge_id], references: [id])

  @@index([enrollment_id])
  @@index([charge_id])

  @@map("payments")
}

model User {
  id       String  @id @default(uuid())
  name     String  @db.VarChar(255)
  email    String  @unique @db.VarChar(255)
  password String
  active   Boolean @default(true)

  @@map("users")
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  PIX
}
